{
  "manifest_version": 3,
  "name": "NovaOS | Personal Productivity Tracker",
  "version": "1.0.0",
  "description": "Automatically track coding activity and website usage for your NovaOS dashboard.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
